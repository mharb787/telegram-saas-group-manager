MASTER_BOT_TOKEN=123456:MASTER_BOT_TOKEN_FROM_BOTFATHER
PORT=3000
DATABASE_PATH=./data/app.sqlite
TOKEN_SECRET=change_this_long_random_secret
DEFAULT_SUBSCRIPTION_DAYS=30
NODE_ENV=development

# Set APP_MODE=real_estate to run the Gaza real estate bot instead of the SaaS manager.
APP_MODE=real_estate
REAL_ESTATE_BOT_TOKEN=123456:REAL_ESTATE_BOT_TOKEN_FROM_BOTFATHER
REAL_ESTATE_BOT_USERNAME=your_bot_username_without_at
ADMIN_CHAT_ID=123456789
GATEWAY_GROUP_ID=
OFFERS_GROUP_ID=@reelstategaza
OFFERS_GROUP_INVITE_LINK=https://t.me/reelstategaza
REGISTRATION_GRACE_MINUTES=15
MAX_GATEWAY_ATTEMPTS=3
